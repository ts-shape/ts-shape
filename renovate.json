{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": [
    "Default Renovate preset for jakobgabriel Python projects.",
    "Covers pep621, pip_requirements, pip_setup, github-actions, and python-version managers.",
    "To reuse: move this file to a jakobgabriel/renovate-config repo and extend via github>jakobgabriel/renovate-config."
  ],
  "extends": [
    "config:recommended",
    ":enableVulnerabilityAlertsWithLabel(security)",
    "security:openssf-scorecard"
  ],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "transitiveRemediation": true,
  "rangeStrategy": "bump",
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 10,
  "assignees": ["jakobgabriel"],
  "commitMessagePrefix": "chore(deps):",
  "platformAutomerge": true,
  "automergeType": "pr",
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "labels": ["security"],
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"]
  },
  "enabledManagers": [
    "pep621",
    "pip_requirements",
    "pip_setup",
    "github-actions",
    "python-version"
  ],
  "python": {
    "fileMatch": ["(^|/)pyproject\\.toml$"]
  },
  "schedule": ["before 9am on Friday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on Friday"]
  },
  "packageRules": [
    {
      "description": "Group core runtime dependencies",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "groupName": "core runtime dependencies",
      "labels": ["dependencies"]
    },
    {
      "description": "Group scientific stack (numpy, pandas, scipy)",
      "matchPackageNames": ["numpy", "pandas", "scipy"],
      "groupName": "scientific stack",
      "labels": ["dependencies", "scientific"]
    },
    {
      "description": "Group cloud storage dependencies (azure-storage-blob, s3fs)",
      "matchPackageNames": ["azure-storage-blob", "s3fs"],
      "groupName": "cloud storage",
      "labels": ["dependencies", "cloud"]
    },
    {
      "description": "Automerge docs dependencies (minor/patch), monthly schedule",
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["requirements-docs.txt"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "docs dependencies",
      "labels": ["docs"],
      "schedule": ["before 9am on the first day of the month"]
    },
    {
      "description": "Dev tools on monthly schedule",
      "matchPackageNames": ["pytest", "pytest-cov", "black", "ruff", "pre-commit", "mypy"],
      "groupName": "dev tools",
      "labels": ["dev-tools"],
      "schedule": ["before 9am on the first day of the month"],
      "automerge": true
    },
    {
      "description": "Automerge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Require manual review for major bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    },
    {
      "description": "Vulnerability fixes bypass schedule and auto-merge with security label",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "labels": ["security"],
      "automerge": true,
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Pin and auto-update GitHub Actions by SHA digest",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true,
      "groupName": "github actions",
      "labels": ["ci"]
    },
    {
      "description": "Tag non-zerover stable releases with deprecation-watch so they show up in the dashboard for review",
      "matchUpdateTypes": ["minor", "patch", "major"],
      "matchCurrentVersion": "!/^0/",
      "addLabels": ["deprecation-watch"]
    }
  ]
}
